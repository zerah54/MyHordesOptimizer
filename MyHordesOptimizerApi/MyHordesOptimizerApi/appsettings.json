{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Discord"
    ],
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Error",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "WithCorrelationId",
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "D:\\Dev\\MHO\\mho.log",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} <{ProcessId} - {ThreadId}> {CorrelationId} [{Level}] =={MhoOrigin} - {MhoScriptVersion}== [{RequestPath}{Query} - {Body}] [{SourceContext}] [{EventId}] {Message}{NewLine}{Exception}",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 419430400,
          "retainedFileCountLimit": 15,
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {CorrelationId} {Level:u3}] {Message:lj} <s:{SourceContext}>{NewLine}{Exception}"
        }
      },
      {
        "Name": "Discord",
        "Args": {
          "webhookId": "0000000000000000000",
          "webhookToken": "dummy",
          "restrictedToMinimumLevel": "Warning"
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {
                "Name": "Discord",
                "Args": {
                  "webhookId": "0000000000000000000",
                  "webhookToken": "dummy",
                  "restrictedToMinimumLevel": "Warning"
                }
              }
            ],
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "StartsWith(SourceContext, 'MyHordesOptimizerApi.Repository.Impl.ExternalTools.FataMorganaRepository')"
                }
              }
            ]
          }
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "MyHordes": {
    "Url": "https://myhordes.de/api/x",
    "AppKey": "dummy",
    "Scrutateur": {
      "Id": 80,
      "Level0": 25,
      "Level1": 37,
      "Level2": 49,
      "Level3": 61,
      "Level4": 73,
      "Level5": 85,
      "StartItemMin": 4,
      "StartItemMax": 8,
      "MinItemAdd": 8,
      "MaxItemAdd": 15,
      "MaxItemPerCell": null,
      "DigThrottle": 10
    }
  },
  "ExternalTools": {
